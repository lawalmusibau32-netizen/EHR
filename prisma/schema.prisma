generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma-client"
}

datasource db {
  provider = "postgresql"
}

model Role {
  roleId      Int     @id @default(autoincrement()) @map("role_id")
  roleName    String  @unique @map("role_name")
  description String?
  isSystem    String  @default("N") @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  users User[]

  @@map("roles")
}

model User {
  userId           Int      @id @default(autoincrement()) @map("user_id")
  roleId           Int      @map("role_id")
  username         String   @unique
  displayName      String   @map("display_name")
  email            String?  @unique
  passwordHash     String   @map("password_hash")
  isActive         String   @default("Y") @map("is_active")
  failedLoginCount Int      @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")
  mfaEnabled       String   @default("N") @map("mfa_enabled")
  mfaSecret        String?  @map("mfa_secret")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  role          Role             @relation(fields: [roleId], references: [roleId])
  authSessions  AuthSession[]
  appointments  Appointment[]    @relation("scheduler")
  clinicianApps Appointment[]    @relation("clinician")
  auditLogs     AuditLog[]
  medicalRecords MedicalRecord[]

  @@map("users")
}

model AuthSession {
  sessionId  Int       @id @default(autoincrement()) @map("session_id")
  userId     Int       @map("user_id")
  jti        String    @unique
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("auth_sessions")
}

model Patient {
  patientId    Int      @id @default(autoincrement()) @map("patient_id")
  mrn          String   @unique
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  dateOfBirth  DateTime @map("date_of_birth")
  sex          String
  phoneNumber  String?  @map("phone_number")
  email        String?  @unique
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String?
  region       String?
  country      String   @default("Ghana")
  isActive     String   @default("Y") @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  medicalRecords MedicalRecord[]
  appointments   Appointment[]

  @@map("patients")
}

model MedicalRecord {
  recordId        Int      @id @default(autoincrement()) @map("record_id")
  patientId       Int      @map("patient_id")
  createdByUserId Int      @map("created_by_user_id")
  recordType      String   @map("record_type")
  title           String
  clinicalNote    String   @map("clinical_note")
  recordStatus    String   @default("ACTIVE") @map("record_status")
  encounterDate   DateTime @default(now()) @map("encounter_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  patient       User                   @relation(fields: [createdByUserId], references: [userId])
  patientRecord Patient                @relation(fields: [patientId], references: [patientId])
  diagnoses     RecordDiagnosis[]
  prescriptions RecordPrescription[]
  treatments    RecordTreatment[]

  @@map("medical_records")
}

model RecordDiagnosis {
  diagnosisId     Int      @id @default(autoincrement()) @map("diagnosis_id")
  recordId        Int      @map("record_id")
  diagnosisName   String   @map("diagnosis_name")
  icd10Code       String?  @map("icd10_code")
  diagnosisStatus String   @default("ACTIVE") @map("diagnosis_status")
  isPrimary       String   @default("N") @map("is_primary")
  isActive        String   @default("Y") @map("is_active")
  diagnosedAt     DateTime @default(now()) @map("diagnosed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  record MedicalRecord @relation(fields: [recordId], references: [recordId])

  @@map("record_diagnoses")
}

model RecordPrescription {
  prescriptionId     Int      @id @default(autoincrement()) @map("prescription_id")
  recordId           Int      @map("record_id")
  medicationName     String   @map("medication_name")
  dosage             String?
  frequency          String?
  route              String?
  durationDays       Int?     @map("duration_days")
  instructions       String?
  prescriptionStatus String   @default("ACTIVE") @map("prescription_status")
  isActive           String   @default("Y") @map("is_active")
  prescribedAt       DateTime @default(now()) @map("prescribed_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @map("updated_at")

  record MedicalRecord @relation(fields: [recordId], references: [recordId])

  @@map("record_prescriptions")
}

model RecordTreatment {
  treatmentId          Int      @id @default(autoincrement()) @map("treatment_id")
  recordId             Int      @map("record_id")
  treatmentName        String   @map("treatment_name")
  treatmentDescription String?  @map("treatment_description")
  treatmentDate        DateTime @default(now()) @map("treatment_date")
  outcome              String?
  notes                String?
  isActive             String   @default("Y") @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @map("updated_at")

  record MedicalRecord @relation(fields: [recordId], references: [recordId])

  @@map("record_treatments")
}

model Appointment {
  appointmentId     Int      @id @default(autoincrement()) @map("appointment_id")
  patientId         Int      @map("patient_id")
  scheduledByUserId Int      @map("scheduled_by_user_id")
  clinicianUserId   Int?     @map("clinician_user_id")
  appointmentDate   DateTime @map("appointment_date")
  appointmentType   String   @map("appointment_type")
  status            String   @default("SCHEDULED")
  reason            String?
  location          String?
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  patient   Patient @relation(fields: [patientId], references: [patientId])
  scheduler User    @relation("scheduler", fields: [scheduledByUserId], references: [userId])
  clinician User?   @relation("clinician", fields: [clinicianUserId], references: [userId])

  @@map("appointments")
}

model InventorySupply {
  supplyId     Int      @id @default(autoincrement()) @map("supply_id")
  name         String
  category     String
  quantity     Int
  unit         String
  reorderLevel Int      @default(10) @map("reorder_level")
  unitCost     Decimal? @map("unit_cost")
  expiryDate   DateTime? @map("expiry_date")
  batchNumber  String?  @map("batch_number")
  manufacturer String?
  notes        String?
  isActive     String   @default("Y") @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  @@map("inventory_supplies")
}

model AuditLog {
  auditLogId Int      @id @default(autoincrement()) @map("audit_log_id")
  userId     Int?     @map("user_id")
  actionType String   @map("action_type")
  entityName String   @map("entity_name")
  entityId   String   @map("entity_id")
  details    String?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [userId])

  @@map("audit_logs")
}
